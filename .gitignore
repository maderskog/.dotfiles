# ── Universal ─────────────────────────────────────────────────────────
.DS_Store
*.bak
*.log
*.wasm
__pycache__/

# ── Oh-my-posh — auto-generated schema ────────────────────────────────
**/oh-my-posh/schema.json

# ── Zed — runtime state, not config ───────────────────────────────────
**/zed/prompts/
**/zed/conversations/

# ── Yazi — timestamped auto-backups ───────────────────────────────────
**/yazi/yazi.toml-*

# ── Nushell — history is machine-local ────────────────────────────────
**/nushell/history.txt

# ── K9s — cluster state and runtime files ─────────────────────────────
**/k9s/clusters/
**/k9s/benchmarks/
**/k9s/screen-dumps/

# ── Tmux — plugins managed by TPM at runtime ──────────────────────────
**/tmux/plugins/

# ── Television — machine-local config ─────────────────────────────────
**/television/agent-files.toml
